{
    // The version of the config file. Do not change this unless you know what you are doing.
    "rconfig:version": 0,
    "showOxygenDistributorArea": false,
    "showGravityNormalizerArea": true,
    "jetSuitEnabled": true,
    // Type: Integer
    "oxygenBarX": 5,
    // Type: Integer
    "oxygenBarY": 25,
    // Type: Float
    "oxygenBarScale": 1.0,
    // Type: Integer
    "energyBarX": 11,
    // Type: Integer
    "energyBarY": 95,
    // Type: Float
    "energyBarScale": 1.0,
    // Reduce volume and increase pitch in space.
    "spaceMuffler": true,
    "Radio": {
        // Range: 0 - 100
        "volume": 50,
        "favorites": []
    }
}