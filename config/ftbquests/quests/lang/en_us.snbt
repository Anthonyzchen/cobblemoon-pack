	quest.5BAD6277AAAA0001.title: "&f&lThe Unearthed Truth"
	quest.5BAD6377AAAA0001.quest_desc: [
		"&8&lThe Forged Future &7- Zekrom is the ideal of the original dragon. To claim its stone, gather the machines of a future yet to come."
		""
